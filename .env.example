# =============================================================================
# ProjectHub — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores
# =============================================================================

# =============================================================================
# Django
# =============================================================================
# Gere uma chave segura com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-troque-em-producao

# True em desenvolvimento, False em produção
DEBUG=False

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1,projecthub.nh.rs.gov.br

# Origins CORS (separados por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost,https://projecthub.nh.rs.gov.br

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=projecthub
POSTGRES_USER=projecthub
POSTGRES_PASSWORD=troque-em-producao

# =============================================================================
# Keycloak OIDC
# Produção: sso.nh.rs.gov.br realm=prefeitura
# Dev local: make keycloak → http://localhost:8080 realm=master
# =============================================================================
KEYCLOAK_SERVER_URL=https://sso.nh.rs.gov.br
KEYCLOAK_REALM=prefeitura

# Client backend — confidential, com client_credentials
KEYCLOAK_CLIENT_ID=projecthub-backend
KEYCLOAK_CLIENT_SECRET=

# Client frontend — public, sem secret (só PKCE)
KEYCLOAK_CLIENT_ID_FRONTEND=projecthub-frontend

# Credenciais admin do Keycloak local (apenas profile:keycloak)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=troque-em-producao

# =============================================================================
# OCI Object Storage (S3-compatible)
# Deixar em branco para usar armazenamento local (desenvolvimento)
# =============================================================================
OCI_ACCESS_KEY=
OCI_SECRET_KEY=
OCI_BUCKET=projecthub-media
OCI_S3_ENDPOINT=
OCI_REGION=sa-saopaulo-1

# =============================================================================
# E-mail
# =============================================================================
EMAIL_HOST=smtp.prefeitura.nh.rs.gov.br
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ProjectHub <projecthub@prefeitura.nh.rs.gov.br>

# =============================================================================
# Frontend (build args Vite — passados pelo docker-compose ao build)
# =============================================================================
VITE_API_URL=https://projecthub.nh.rs.gov.br/api/v1
VITE_WS_URL=wss://projecthub.nh.rs.gov.br/ws

# =============================================================================
# Flower — monitoramento Celery (profile:monitoring)
# =============================================================================
FLOWER_USER=admin
FLOWER_PASSWORD=troque-em-producao

# =============================================================================
# Sentry (opcional)
# =============================================================================
SENTRY_DSN=
ENVIRONMENT=production
